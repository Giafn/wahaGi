// This is your Prisma schema file
// LID (Legacy ID) is used as the primary identifier for WhatsApp contacts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]
  media        Media[]

  @@map("users")
}

model Session {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String
  status     String    @default("disconnected") // connected | connecting | disconnected | qr
  webhookUrl String?   @map("webhook_url")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastSeen   DateTime? @map("last_seen")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Media {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  filename  String
  path      String
  mimeType  String   @map("mime_type")
  size      Int
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("media")
}

model ChatHistory {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  messageId String?  @map("message_id") // WhatsApp message ID for edit tracking
  from      String   // WhatsApp LID (primary identifier)
  message   String
  type      String   @default("text") @map("message_type")
  isFromMe  Boolean  @default(false) @map("is_from_me")
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([sessionId, from])
  @@index([sessionId, timestamp])
  @@index([from])
  @@index([messageId])
  @@map("chat_history")
}

model Chat {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  lid        String   // WhatsApp LID (primary identifier)
  name       String?
  unreadCount Int     @default(0) @map("unread_count")
  lastMessageTime DateTime? @map("last_message_time")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt

  @@unique([sessionId, lid])
  @@index([sessionId])
  @@map("chats")
}
