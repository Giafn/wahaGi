# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/baileys_api"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY="7d"

# Admin credentials (for initial setup)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Server
PORT=3000
HOST="0.0.0.0"

# Media storage
MEDIA_DIR="./media"
AUTH_DIR="./auth"

# Public URL (for webhook media URLs)
PUBLIC_URL="http://localhost:3000"

# Send media delay (ms)
MEDIA_SEND_DELAY_MIN=500
MEDIA_SEND_DELAY_MAX=1000

# Webhook retry
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY=2000
