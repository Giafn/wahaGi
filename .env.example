# Database (update with your external PostgreSQL credentials)
DATABASE_URL="postgresql://gia:password@localhost:5432/wahagi"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRY="7d"

# Admin credentials (for initial setup)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Server - Custom Port
PORT=3021
HOST="0.0.0.0"

# Media storage
MEDIA_DIR="./media"
AUTH_DIR="./auth"

# Public URL (for webhook media URLs)
PUBLIC_URL="http://localhost:3021"

# Send media delay (ms) - for multiple media
MEDIA_SEND_DELAY_MIN=500
MEDIA_SEND_DELAY_MAX=1000

# Webhook retry
WEBHOOK_RETRY_COUNT=3
WEBHOOK_RETRY_DELAY=2000

# Debug logging (set to 'true' to enable verbose logs)
DEBUG=true
